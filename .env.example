VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Function secrets (set via: supabase secrets set KEY=value)
# MP_ACCESS_TOKEN=TEST-...           MercadoPago access token (TEST- prefix for sandbox)
# MP_WEBHOOK_SECRET=...              MercadoPago webhook secret (REQUIRED — webhooks return 401 if missing)
# RESEND_API_KEY=re_...              Resend email API key
# RESEND_FROM_EMAIL=Lo de Granados <noreply@lodegranados.com>
# SITE_URL=https://lodegranados-v2-chi.vercel.app
